# homeESS – Beispiel-Umgebungskonfiguration
#
# Diese Datei ist eine Vorlage. Kopiere sie nach `.env` und passe die Werte an.
# `.env` selbst ist über .gitignore ausgeschlossen und wird nie eingecheckt.
# Alle Variablen sind optional; ohne sie greifen die eingebauten Defaults.

# HTTP-Port der Weboberfläche (Default: 3000)
# PORT=3000

# Pfad zur SQLite-Datenbank (Default: data/app.db)
# HOME_ESS_DB=./data/app.db

# Verzeichnis der Adapter-Unterordner (Default: ./adapter)
# HOME_ESS_ADAPTER_DIR=./adapter

# --- Fernzugriff / Pairing (essrelay) ------------------------------------
#
# Basis-URL des Relay-Servers. Wird ausschließlich serverseitig festgelegt und
# NIE aus einem Browser-Request übernommen (SSRF-Schutz). Der homeESS-Server ist
# der Relay-Client; der Browser spricht nie direkt mit dem essrelay.
#
# Regeln: absolute https://-URL, ohne Benutzer/Passwort, ohne Query, ohne
# Fragment. Ein ungültiger Wert lässt den Serverstart bewusst scheitern.
# Default: https://essrelay.mykaefer.net
# ESS_RELAY_BASE_URL=https://essrelay.mykaefer.net

# Instanzname, den homeESS beim Erstellen einer Pairing-Session an den Relay
# meldet (erscheint später in der App). Default: homeESS
# HOME_ESS_INSTANCE_NAME=homeESS

# --- Dauerhafte Instanzidentität / Origin-WebSocket (essrelay 0.5.0) ------
#
# Verzeichnis der dauerhaften Ed25519-Instanzidentität (privater Schlüssel +
# Metadaten). MUSS dem homeESS-Servicebenutzer gehören und darf nicht
# weltlesbar sein. Default: <data>/identity (z. B. ./data/identity), bereits
# über .gitignore ausgeschlossen. Alternativ z. B. /var/lib/home-ess/identity.
# HOME_ESS_IDENTITY_DIR=/var/lib/home-ess/identity

# WebSocket-URL des Origin-Endpunkts am Relay. Standardmäßig aus der Basis-URL
# abgeleitet (wss://<host>/api/v1/ws/homeess). Nur setzen, wenn der Relay den
# Origin-Endpunkt unter einem anderen Pfad/Host anbietet. Muss wss:// sein.
# ESS_RELAY_WS_URL=wss://essrelay.mykaefer.net/api/v1/ws/homeess

# Origin-WebSocket-Autostart nach Provisioning abschalten (nur Identität und
# Pairing, keine WebSocket-Verbindung). Beliebiger Wert = 1 deaktiviert.
# ESS_RELAY_CONNECTION_DISABLED=1
